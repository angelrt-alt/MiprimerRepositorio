Algoritmo notasdeestudiantes
	definir nota Como Entero
	
	escribir "ingresar la nota del estudian de 1 a 10"
	leer nota
	
	si nota >= 6 Entonces
        Escribir "Aprobado"
		
		 Sino
        Si nota <= 4 Entonces
            Escribir "Reprobado"
        Sino
            Si nota = 5 Entonces
                Escribir "Recuperación"
		FinSi
	finsi
FinSi

	
FinAlgoritmo
